# ── SERVER ──────────────────────────────────────────
PORT=5000

# ── DATABASE (Neon) ──────────────────────────────────
# Get this from neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── JWT SECRET ───────────────────────────────────────
# Make this long and random — never share it
JWT_SECRET=VibeOrbit2024SuperSecretKeyChangeThisToSomethingRandom

# ── CLOUDINARY ───────────────────────────────────────
# Get from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── EMAIL (Gmail) ────────────────────────────────────
# Use a Gmail app password (NOT your real password)
# Instructions: myaccount.google.com → Security → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ── M-PESA (Daraja Sandbox) ──────────────────────────
# Get from developer.safaricom.co.ke → My Apps
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey_from_daraja
# Update this after deploying backend to Render:
MPESA_CALLBACK_URL=https://YOUR-RENDER-URL.onrender.com/api/pay/callback

# ── FRONTEND URL ─────────────────────────────────────
# Update this after deploying frontend to Netlify:
FRONTEND_URL=http://localhost:3000
